# ─────────────────────────────────────────────────────────────────────────────
# ChurnGuard AI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/churnguard

# SQLite (local development — no setup required, just remove the line above)
# DATABASE_URL=sqlite:///./churnguard.db

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Set to "production" in prod environments
APP_ENV=development
SECRET_KEY=change-me-to-a-random-secret-string

# ── Optional: override API URL in Streamlit pages ─────────────────────────────
API_BASE_URL=http://127.0.0.1:8000
